# ── InfluxDB ──────────────────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=change-me-to-a-secure-token
INFLUXDB_ORG=wetter
INFLUXDB_BUCKET_WEATHER=weather
INFLUXDB_BUCKET_ENERGY=energy
INFLUXDB_BUCKET_FORECASTS=forecasts

# ── Ecowitt (Keys von https://api.ecowitt.net) ───────
ECOWITT_APP_KEY=
ECOWITT_API_KEY=
ECOWITT_MAC=

# ── Growatt (ShinePhone Login) ────────────────────────
# Nur noetig wenn Growatt-Inverter vorhanden
GROWATT_USERNAME=
GROWATT_PASSWORD=
# Plant ID und Inverter SN findest du unter server.growatt.com
GROWATT_PLANT_ID=
GROWATT_INVERTER_SN=

# ── Standort ──────────────────────────────────────────
LATITUDE=-32.1559
LONGITUDE=-64.7916
ALTITUDE=1000
TIMEZONE=America/Argentina/Cordoba

# ── Server ────────────────────────────────────────────
BACKEND_PORT=8000
