# ── InfluxDB ──────────────────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=change-me-to-a-secure-token
INFLUXDB_ORG=offgrid
INFLUXDB_BUCKET_WEATHER=weather
INFLUXDB_BUCKET_ENERGY=energy
INFLUXDB_BUCKET_FORECASTS=forecasts

# ── Ecowitt (Keys von https://api.ecowitt.net) ───────
ECOWITT_APP_KEY=
ECOWITT_API_KEY=
ECOWITT_MAC=

# ── Growatt (ShinePhone Login) ────────────────────────
# Nur noetig wenn Growatt-Inverter vorhanden
GROWATT_USERNAME=
GROWATT_PASSWORD=
# Plant ID und Inverter SN findest du unter server.growatt.com
GROWATT_PLANT_ID=
GROWATT_INVERTER_SN=
# Klassischer ShinePhone-Server (SPF-Off-Grid-Inverter). Bei 403-Fehlern
# alternativ https://server-api.growatt.com probieren.
GROWATT_SERVER_URL=https://server.growatt.com

# ── Standort (Default-Site beim ersten Start) ─────────
# Nach dem ersten Speichern in der Settings-Seite kommen alle Werte
# (inkl. mehrerer Standorte) aus data/settings.json statt aus dieser Datei.
LATITUDE=-32.1559
LONGITUDE=-64.7916
ALTITUDE=1000
TIMEZONE=America/Argentina/Cordoba

# ── Server ────────────────────────────────────────────
BACKEND_PORT=8000

# ── Berichte (PDF per E-Mail) ─────────────────────────
# SMTP-Zugangsdaten sind Geheimnisse und bleiben in der .env. Empfaenger,
# An/Aus und Intervall (weekly|monthly) sind danach in der Settings-Seite
# (Tab "Berichte") editierbar; diese Werte sind nur die Startwerte.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
REPORT_EMAIL_FROM=wetter@example.com
REPORT_EMAIL_TO=
# weekly = Montag 08:00, monthly = 1. des Monats 08:00, off = aus
REPORT_SCHEDULE=weekly

# ── Admin / Settings ──────────────────────────────────
# PIN zum Schutz der Settings-Seite (/settings.html) und der Admin-API.
# Leer lassen = beim ersten Start wird automatisch ein PIN generiert und in
# DATA_DIR/admin_pin.txt abgelegt (dort nachlesen). Die Admin-API ist damit
# nie unbeabsichtigt offen.
ADMIN_PIN=
# Nur fuer Entwicklung / vollstaendig vertrauenswuerdige Netze: true schaltet
# den PIN-Schutz komplett ab.
ADMIN_ALLOW_OPEN=false

# ── CORS ──────────────────────────────────────────────
# Kommagetrennte Frontend-Origins, die die API aus dem Browser aufrufen
# duerfen (z.B. http://192.168.1.10:8080). Leer = kein Cross-Origin-Zugriff;
# das ist korrekt, wenn das Backend die PWA selbst ausliefert
# (docker-compose-Standard). "*" stellt das alte offene Verhalten wieder her.
CORS_ORIGINS=

# Pfad fuer die persistente settings.json (im Docker als Volume gemountet).
DATA_DIR=/app/data
